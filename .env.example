# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Copy to .env and fill in real values.
# NEVER commit the real .env file to version control.
# Variables marked "required" will cause the app/container to refuse to start.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://yourdomain.com
NEXTAUTH_URL=https://yourdomain.com

# ── Auth (REQUIRED) ───────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_openssl_rand_hex_64

# ── Database (REQUIRED) ───────────────────────────────────────────────────────
DATABASE_URL=postgresql://ecom_user:CHANGE_ME@localhost:5432/ecommerce_db
POSTGRES_DB=ecommerce_db
POSTGRES_USER=ecom_user
POSTGRES_PASSWORD=CHANGE_ME   # min 32 random chars in production

# ── Stripe (REQUIRED) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_CHANGE_ME

# ── Email SMTP ────────────────────────────────────────────────────────────────
SMTP_HOST=ssl0.ovh.net
SMTP_PORT=587
SMTP_USER=contact@yourdomain.com
SMTP_PASS=CHANGE_ME
SMTP_FROM="Boutique <contact@yourdomain.com>"
ADMIN_EMAIL=admin@yourdomain.com

# ── Admin bootstrap (seed only — remove after first deploy) ───────────────────
ADMIN_PASSWORD=CHANGE_ME   # min 12 chars, rotated immediately after first login

# ── Cron (REQUIRED) ───────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
CRON_SECRET=CHANGE_ME_openssl_rand_hex_32
